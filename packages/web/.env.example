# Copy to .env and fill after `cdk deploy` (use stack outputs).
# VITE_COGNITO_USER_POOL_ID=<UserPoolId>
# VITE_COGNITO_CLIENT_ID=<UserPoolClientId>
# VITE_API_URL=<ApiUrl>

VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_API_URL=

# Set to "true" to bypass Cognito and auto-login as a mock super-admin.
# Use for local development of the /admin/* pages.
# VITE_SUPER_ADMIN_MODE=true
